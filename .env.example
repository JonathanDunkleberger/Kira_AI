# ============================================================================
#  KIRA — environment configuration
#  Copy this file to `.env` and fill in the values you need.
#  Every var below has a sane default in kira/config.py; only the keys in the
#  MINIMUM REQUIRED block are needed to boot the core voice loop.
# ============================================================================

# ----------------------------------------------------------------------------
#  💸 HEADS-UP: PERCEPTION IS ON BY DEFAULT (a fresh clone costs money to idle)
#  Out of the box Kira boots with her senses awake:
#    • Vision      (ENABLE_VISION=true)            → OpenAI vision calls, ~40s heartbeat
#    • Audio-mood  (AUDIO_MOOD_ALWAYS_ON=true)     → OpenAI audio calls, ~12s heartbeat
#    • Mic Whisper (faster-whisper large-v3)       → local GPU (~1.5 GB VRAM)
#    • Loopback Whisper (distil-large-v3, ENABLE_LOOPBACK_TRANSCRIBER=true)
#                                                  → SECOND local GPU model (~1.5 GB VRAM)
#  → That's TWO Whisper models on the GPU + recurring OpenAI vision/audio spend
#    even when she's sitting idle. To boot cheap/quiet, set in your .env:
#       ENABLE_VISION=false
#       AUDIO_MOOD_ALWAYS_ON=false   (or ENABLE_AUDIO_AGENT=false)
#       ENABLE_LOOPBACK_TRANSCRIBER=false
#  See the VISION / AUDIO blocks below for the per-flag details.
# ----------------------------------------------------------------------------

# ============================================================================
#  ⭐ MINIMUM REQUIRED TO BOOT (the core voice loop) ⭐
#  Fill these five and `python run.py` will run with the default config.
#  Everything below this block is optional / feature-gated.
# ============================================================================

# Claude — Kira's main brain (Sonnet live voice + Opus deep moments). PAID.
#   Get a key: https://console.anthropic.com/  →  API Keys
ANTHROPIC_API_KEY=

# Groq — default triage / fast-path inference (llama-3.1-8b-instant). FREE tier.
#   Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Azure Cognitive Services Speech — default TTS voice (word timing for captions). PAID (free tier available).
#   Create a Speech resource: https://portal.azure.com/  →  "Speech service"
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus3

# OpenAI — vision agent + the audio-mood agent. BOTH are ON by default
#   (ENABLE_VISION=true and ENABLE_AUDIO_AGENT=true), so this key is needed out
#   of the box and bills on idle. To skip it, set ENABLE_VISION=false and
#   ENABLE_AUDIO_AGENT=false (and AUDIO_MOOD_ALWAYS_ON=false). PAID.
#   Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ============================================================================
#  INFERENCE BACKEND  — # PICK ONE: groq (default) or local
# ============================================================================
# "groq"  -> Groq cloud (llama-3.1-8b-instant). Saves ~6-7 GB VRAM. Default.
# "local" -> on-device llama_cpp GGUF. Requires `pip install -r
#            requirements-local.txt` + a GGUF weight file (see LLM_MODEL_PATH).
INFERENCE_BACKEND=groq                 # REQUIRED

# -- groq backend ------------------------------------------------------------
GROQ_MODEL=llama-3.1-8b-instant        # OPTIONAL
GROQ_TIMEOUT=5.0                       # OPTIONAL
# Fallback when Groq fails:
#   false      -> raise (no resilience, no VRAM cost)
#   true       -> keep local Llama loaded as warm fallback (needs requirements-local.txt)
#   lazy_load  -> load local Llama only if/when Groq fails (recommended)
GROQ_FALLBACK_TO_LOCAL=lazy_load       # OPTIONAL

# -- local backend (only if INFERENCE_BACKEND=local, or fallback uses local) --
# Needs: pip install -r requirements-local.txt  +  a GGUF file at this path.
LLM_MODEL_PATH=models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf   # REQUIRED-IF-LOCAL
N_GPU_LAYERS=-1                        # OPTIONAL  -1 = all layers on GPU (~6-7 GB)
N_CTX=16384                            # OPTIONAL
N_BATCH=512                            # OPTIONAL
LLM_MAX_RESPONSE_TOKENS=512            # OPTIONAL


# ============================================================================
#  CLAUDE BRAIN (main responses; uses ANTHROPIC_API_KEY above)
# ============================================================================
CLAUDE_DEEP_MODEL=claude-opus-4-7      # OPTIONAL  Opus — deep moments / artifacts
CLAUDE_CHAT_MODEL=claude-sonnet-4-6    # OPTIONAL  Sonnet — live voice turns
CLAUDE_HAIKU_MODEL=claude-haiku-4-5    # OPTIONAL  Haiku — per-turn memory extraction
ENABLE_CLAUDE_BRAIN=true               # OPTIONAL
ENABLE_CLAUDE_CHAT=true                # OPTIONAL
ENABLE_PROMPT_CACHING=true             # OPTIONAL
ENABLE_CLAUDE_STREAMING=true           # OPTIONAL


# ============================================================================
#  TTS VOICE  — # PICK ONE backend: azure (default) | fish | edge
# ============================================================================
# TTS_BACKEND selects azure vs fish at runtime (dashboard toggle overrides).
# Keep this 'azure' — booting straight into 'fish' was a recurring bug; switch
# to fish live from the dashboard instead. 'edge' (free, no key) is the
# automatic fallback when Azure is unavailable, but gives no per-word caption
# timing.
TTS_BACKEND=azure                      # REQUIRED

# TTS_ENGINE is VESTIGIAL — superseded by TTS_BACKEND. Left for compatibility;
# leave as 'edge'. Has no effect on the azure/fish selection.
TTS_ENGINE=edge                        # OPTIONAL (vestigial)

# -- Azure TTS (if TTS_BACKEND=azure) — uses AZURE_SPEECH_KEY/REGION above ----
AZURE_SPEECH_VOICE=en-US-AshleyNeural  # OPTIONAL
AZURE_PROSODY_RATE=25%                 # OPTIONAL
AZURE_PROSODY_PITCH=+25%               # OPTIONAL

# -- Fish Audio TTS (if TTS_BACKEND=fish) — pay-as-you-go --------------------
FISH_API_KEY=                          # REQUIRED-IF-FISH
FISH_VOICE_ID=                         # REQUIRED-IF-FISH  reference_id of the voice model
FISH_LATENCY=balanced                  # OPTIONAL  normal | balanced
FISH_FORMAT=mp3                        # OPTIONAL  mp3 | wav | pcm | opus

# -- ElevenLabs — VESTIGIAL (not used by the live TTS path; kept for legacy) --
ELEVENLABS_API_KEY=                    # OPTIONAL (vestigial)
ELEVENLABS_VOICE_ID=                   # OPTIONAL (vestigial)


# ============================================================================
#  SPEECH-TO-TEXT / VAD  (mic capture — local, CUDA Whisper)
# ============================================================================
WHISPER_MODEL_SIZE=large-v3            # OPTIONAL  faster-whisper auto-downloads (~1.5 GB) on first boot
# Where faster-whisper caches downloaded weights (defaults to models/whisper).
# WHISPER_CACHE_DIR=models/whisper     # OPTIONAL
PAUSE_THRESHOLD=0.4                    # OPTIONAL  seconds of silence = end-of-speech
VAD_AGGRESSIVENESS=3                   # OPTIONAL  0-3 (3 = most aggressive)
AI_NAME=Kira                           # OPTIONAL


# ============================================================================
#  VISION  (screen understanding — uses OPENAI_API_KEY above)
# ============================================================================
# ON by default → always-on "calm" perception (a low-cadence heartbeat so she's
# never blind). Bills OpenAI vision calls while running. Set false to go dark.
ENABLE_VISION=true                     # OPTIONAL  ON by default → needs OPENAI_API_KEY
# Calm-baseline seconds between idle vision captures. The dashboard "Deep Senses"
# toggle escalates this to a fast ~10s cadence for active gaming/watching.
VISION_CALM_HEARTBEAT_SECONDS=40.0     # OPTIONAL  higher = cheaper/calmer


# ============================================================================
#  AUDIO UNDERSTANDING  (Kira hears desktop game/music audio)
# ============================================================================
ENABLE_AUDIO_AGENT=true                # OPTIONAL  ON by default → needs OPENAI_API_KEY
# Keep the audio-mood read running as part of always-on calm perception (so she
# always has a coarse sense of the on-screen score/mood). Bills OpenAI audio
# calls on the heartbeat below. Set false to only hear audio when a mode arms it.
AUDIO_MOOD_ALWAYS_ON=true              # OPTIONAL  ON by default → idle OpenAI audio spend
VIRTUAL_AUDIO_DEVICE=CABLE Input (VB-Audio Virtual Cable)   # REQUIRED-IF-ON  install VB-Audio Virtual Cable
AUDIO_HEARTBEAT_SECONDS=12.0           # OPTIONAL
AUDIO_CLIP_SECONDS=8.0                 # OPTIONAL
AUDIO_MODEL=gpt-4o-mini-audio-preview-2024-12-17   # OPTIONAL
# AudD song-fingerprinting (paid; only fires on explicit song-ID intent).
AUDD_API_TOKEN=                        # REQUIRED-IF-SONG-ID

# -- Loopback Whisper transcriber (English desktop ASR for stream-watching) --
# ON by default → loads a SECOND local Whisper (distil-large-v3, ~1.5 GB VRAM)
# on top of the mic Whisper. English-only: produces garbage on JP/VN audio, so
# set false for non-English co-watch (and to reclaim the VRAM / skip a 2nd model).
ENABLE_LOOPBACK_TRANSCRIBER=true       # OPTIONAL  ON by default → 2nd GPU Whisper (~1.5 GB)
# Whether loopback STT auto-starts when MEDIA audio mode turns on.
LOOPBACK_STT_DEFAULT=true              # OPTIONAL  ON by default


# ============================================================================
#  TWITCH  (chat read/post — REQUIRED-IF-ON: ENABLE_TWITCH_CHAT)
# ============================================================================
ENABLE_TWITCH_CHAT=true                # OPTIONAL
TWITCH_OAUTH_TOKEN=                    # REQUIRED-IF-ON  https://twitchtokengenerator.com/
TWITCH_BOT_USERNAME=                   # REQUIRED-IF-ON
TWITCH_CHANNEL_TO_JOIN=                # REQUIRED-IF-ON
TWITCH_CLIENT_ID=                      # REQUIRED-IF-POLLS  (twitch_tools: polls/predictions)
BROADCASTER_ID=                        # REQUIRED-IF-POLLS  numeric Twitch user id
# Pass the broadcaster's OWN messages through to Kira (set true when the bot
# account == the broadcaster account; safe to leave true).
ALLOW_BROADCASTER_CHAT=false           # OPTIONAL
# Twitch native polls require affiliate status (else [POLL:] tags are stripped).
ENABLE_TWITCH_POLLS=false              # OPTIONAL

# -- Kira typing in her own chat (rare second expression channel) ------------
# When true, Kira can emit [CHAT: message] to type a SHORT line into Twitch chat.
# YouTube posting is NOT implemented (pytchat is read-only).
ENABLE_CHAT_POSTING=false              # OPTIONAL
CHAT_POST_COOLDOWN_SEC=60.0            # OPTIONAL  global transport floor (all posters)
CHAT_POST_MAX_LEN=450                  # OPTIONAL  Twitch hard cap is 500
ENABLE_YOUTUBE_POSTING=false           # OPTIONAL  (not implemented)
CHAT_POST_KIRA_INTERVAL_SEC=300.0      # OPTIONAL  min seconds between HER posts
CHAT_POST_KIRA_MAX_PER_SESSION=8       # OPTIONAL  hard session ceiling
CHAT_POST_KIRA_MAX_LEN=200             # OPTIONAL  her chat lines stay short


# ============================================================================
#  YOUTUBE  (live chat read — REQUIRED-IF-ON: ENABLE_YOUTUBE_CHAT)
# ============================================================================
ENABLE_YOUTUBE_CHAT=true               # OPTIONAL
# Set YOUTUBE_CHANNEL_ID to auto-poll for a live stream on boot (else connect
# manually from the dashboard).
YOUTUBE_CHANNEL_ID=                    # REQUIRED-IF-AUTOCONNECT
YT_AUTO_CONNECT_TIMEOUT_S=900          # OPTIONAL  give up after 15 min
YT_AUTO_CONNECT_POLL_S=60              # OPTIONAL


# ============================================================================
#  WEB SEARCH  (Google Custom Search — REQUIRED-IF-ON)
# ============================================================================
GOOGLE_API_KEY=                        # REQUIRED-IF-ON  https://console.cloud.google.com/
GOOGLE_CSE_ID=                         # REQUIRED-IF-ON  https://programmablesearchengine.google.com/


# ============================================================================
#  STORYTIME / PUPPET SHOW  (pre-generated shadow-puppet shows)
# ============================================================================
# Image gen uses Google Gemini 2.5 Flash Image ("Nano-Banana"). This is a FRESH
# Google AI Studio key, SEPARATE from GOOGLE_API_KEY (Custom Search) above.
GEMINI_IMAGE_API_KEY=                  # REQUIRED-IF-ON  https://aistudio.google.com/apikey
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image   # OPTIONAL
STORYTIME_IMAGE_PROVIDER=gemini        # OPTIONAL


# ============================================================================
#  CHESS MODE  (Kira plays Lichess vs Stockfish — REQUIRED-IF-ON)
# ============================================================================
# Requires a SEPARATE Lichess BOT account + a bot:play token, and a local
# Stockfish binary. See README "Chess Mode" for the one-time account upgrade.
# Disabled unless armed from the dashboard. CPU only.
LICHESS_BOT_TOKEN=                     # REQUIRED-IF-ON  https://lichess.org/account/oauth/token
CHESS_ENGINE_PATH=stockfish.exe        # REQUIRED-IF-ON  path to Stockfish binary
CHESS_KIRA_ELO=1400                    # OPTIONAL  Stockfish Elo cap
CHESS_MOVETIME_MS=150                  # OPTIONAL  engine think time per move (ms)
# Challenges from this Lichess id are treated as the owner's practice games
# (no spectate embed on stream). Set to your own Lichess username.
CHESS_OWNER_LICHESS_ID=                # OPTIONAL


# ============================================================================
#  VTUBE STUDIO  (mood-driven Live2D expressions — REQUIRED-IF-ON)
# ============================================================================
ENABLE_VTS_EXPRESSIONS=true            # OPTIONAL
VTS_WS_URL=ws://localhost:8001         # OPTIONAL  VTube Studio API endpoint
VTS_PLUGIN_NAME=Kira AI                # OPTIONAL
VTS_PLUGIN_DEVELOPER=JonnyD            # OPTIONAL
# VTS_TOKEN_PATH=.vts_token            # OPTIONAL  auto-created on first handshake


# ============================================================================
#  CAPTIONS & DASHBOARD
# ============================================================================
# On-screen caption overlay (OBS browser source). Azure TTS gives word timing.
ENABLE_CAPTIONS=false                  # OPTIONAL
CAPTION_SERVER_PORT=8765               # OPTIONAL
CAPTION_CLEAR_DELAY_MS=1500            # OPTIONAL
# Local web control panel (FastAPI, 127.0.0.1 only). Open http://127.0.0.1:8766/
CONTROL_SERVER_PORT=8766               # OPTIONAL


# ============================================================================
#  MEMORY
# ============================================================================
MEMORY_PATH=memory_db/                 # OPTIONAL


# ============================================================================
#  DISCORD  (end-of-session diary webhook — REQUIRED-IF-ON)
# ============================================================================
# Kira writes an in-character diary entry, SAVED for review (not auto-posted).
DISCORD_WEBHOOK_URL=                    # REQUIRED-IF-ON
# Flip true to let the diary fire to the webhook automatically (off until trusted).
DISCORD_AUTOPOST=false                 # OPTIONAL


# ============================================================================
#  GAME MODE / HIGHLIGHTS / STREAM LOGGING
# ============================================================================
# When true, the dashboard ACTIVATE button auto-configures all subsystems to
# stream-ready state (Vision ON, Audio=MEDIA, Highlights ON, etc.).
GAME_MODE_AUTO_CONFIGURE=true           # OPTIONAL
CUTSCENE_AWARE=true                     # OPTIONAL  suppress interjections during cutscenes (ACTIVITY_GAME only)
HIGHLIGHT_EXTRACTION_ENABLED=true       # OPTIONAL  background Opus highlight loop
HIGHLIGHT_EXTRACTION_INTERVAL_SECONDS=300   # OPTIONAL
CHECKPOINT_INTERVAL=300                 # OPTIONAL  playthrough crash-recovery flush (seconds)
STREAM_LOGGING_ENABLED=true             # OPTIONAL  transcript/events/summary per session


# ============================================================================
#  AUTO-CLIP PIPELINE  (offline, post-session — scripts/cut_clips.py)
# ============================================================================
# OBS_RECORDINGS_DIR is where OBS writes local recordings. Cut clips land in
# OBS_RECORDINGS_DIR/clips/YYYY-MM-DD/. Set to your own recordings folder.
OBS_RECORDINGS_DIR=                     # REQUIRED-IF-CLIPPING
CLIP_PRE_SECONDS=6.5                    # OPTIONAL  lead-in before the moment
CLIP_POST_SECONDS=3.5                   # OPTIONAL  payoff after the moment
REEL_MIN_MINUTES=20                     # OPTIONAL  skip the reel below this session length
CLIP_VIDEO_EXTS=.mkv,.mp4,.flv,.mov,.ts # OPTIONAL


# ============================================================================
#  CHAT TUNING  (batching, presence dials, throttles — all OPTIONAL)
# ============================================================================
CHAT_BATCH_WINDOW=5.0                   # OPTIONAL
CHAT_RESPONSE_COOLDOWN=8.0              # OPTIONAL
ENABLE_CHATTER_MEMORY=true              # OPTIONAL
# Presence dial — probability a bored-loop line becomes a question to chat,
# per presence level (Sleepy / Normal / Chatty).
ASK_CHAT_P_SLEEPY=0.05                  # OPTIONAL
ASK_CHAT_P_NORMAL=0.15                  # OPTIONAL
ASK_CHAT_P_CHATTY=0.25                  # OPTIONAL
# Silence-threshold multiplier per presence level (>1 = sleepier, <1 = chattier).
PRESENCE_THRESHOLD_MULT_SLEEPY=1.8      # OPTIONAL
PRESENCE_THRESHOLD_MULT_NORMAL=1.0      # OPTIONAL
PRESENCE_THRESHOLD_MULT_CHATTY=0.8      # OPTIONAL
# If the oldest pending chat message waits longer than this, inject a quick ack.
ACK_THRESHOLD_S=20.0                    # OPTIONAL
# Talk-budget governor — bias batch ordering toward less-answered chatters.
CHAT_BUDGET_ENABLED=false               # OPTIONAL
CHAT_BUDGET_RESPOND_ALL_N=5             # OPTIONAL
# Phrase throttle — soft do-not-reuse constraint when a phrase repeats.
PHRASE_THROTTLE_ENABLED=true            # OPTIONAL
PHRASE_THROTTLE_THRESHOLD=2             # OPTIONAL
PHRASE_THROTTLE_WATCHLIST=three words and a vibe,and a vibe,I respect it,I respect the commitment,I'll wait   # OPTIONAL
# Cooldown (seconds) for the word-count narration tic family.
FRAGMENT_QUIP_COOLDOWN_S=240            # OPTIONAL

# -- AI Core Settings --
LLM_MODEL_PATH=models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
N_GPU_LAYERS=-1
N_CTX=4096
N_BATCH=512
LLM_MAX_RESPONSE_TOKENS=512
WHISPER_MODEL_SIZE=medium.en

# -- TTS Settings --
TTS_ENGINE=azure
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# -- Azure TTS Settings -- 
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus3
AZURE_SPEECH_VOICE=en-US-AshleyNeural
AZURE_PROSODY_RATE=25%
AZURE_PROSODY_PITCH=+25%

# -- Bot Settings --
AI_NAME=Kira
PAUSE_THRESHOLD=0.8
VAD_AGGRESSIVENESS=3

# -- Twitch Settings --
TWITCH_OAUTH_TOKEN=
TWITCH_BOT_USERNAME=
TWITCH_CHANNEL_TO_JOIN=
TWITCH_CLIENT_ID=
BROADCASTER_ID=

# -- Web Search Settings --
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# -- Vision (OpenAI API for screen understanding) --
OPENAI_API_KEY=

# -- Feature Flags --
ENABLE_TWITCH_CHAT=true
ENABLE_YOUTUBE_CHAT=true
CHAT_BATCH_WINDOW=5.0
CHAT_RESPONSE_COOLDOWN=8.0
ENABLE_CHATTER_MEMORY=true

# -- Hybrid Brain (Claude Opus for deep moments) --
ANTHROPIC_API_KEY=
CLAUDE_DEEP_MODEL=claude-opus-4-7
ENABLE_CLAUDE_BRAIN=true
CLAUDE_CHAT_MODEL=claude-sonnet-4-6
ENABLE_CLAUDE_CHAT=true
ENABLE_PROMPT_CACHING=true
ENABLE_CLAUDE_STREAMING=true
WHISPER_MODEL_SIZE=large-v3

# -- Inference Backend (triage / classification / fallback response) --
# Claude (Sonnet/Opus) handles main responses and is NOT affected by this.
# "groq"  -> route llama-3.1-8b-instant to Groq cloud, saves ~6-7 GB VRAM.
# "local" -> use the local llama_cpp GGUF (legacy behavior).
INFERENCE_BACKEND=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=5.0
# Fallback when Groq fails:
#   false      -> raise (no resilience, no VRAM cost)
#   true       -> keep local Llama loaded as warm fallback (no VRAM savings)
#   lazy_load  -> load local Llama only if/when Groq fails (recommended)
GROQ_FALLBACK_TO_LOCAL=lazy_load

# -- Memory Settings --
MEMORY_PATH=memory_db/

# -- Audio Settings --
VIRTUAL_AUDIO_DEVICE=CABLE Input (VB-Audio Virtual Cable)

# -- Audio Understanding (Kira hears game/music) --
ENABLE_AUDIO_AGENT=true
AUDIO_HEARTBEAT_SECONDS=12.0
AUDIO_CLIP_SECONDS=8.0
AUDIO_MODEL=gpt-audio-mini

# -- Loopback Whisper Transcriber (English ASR for stream-watching) --
# Off by default. Distil-large-v3 is English-only and produces garbage on JP/VN
# audio. Enable ONLY for English stream-watching co-watch sessions.
# For Bond-style English AAA games: set true and swap WHISPER_MODEL_SIZE to
# distil-large-v3 to free ~1.5 GB VRAM for the second Whisper instance.
ENABLE_LOOPBACK_TRANSCRIBER=false

# -- Cutscene-aware observer suppression (ACTIVITY_GAME only) --
# When true, Kira suppresses bored interjections and biases triage toward
# STAY_QUIET when vision/audio cues suggest a cutscene is playing.
# Has NO effect outside ACTIVITY_GAME mode.
CUTSCENE_AWARE=true
